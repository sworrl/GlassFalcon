<!-- Quadcopter-battery hybrid HUD glyph: a battery cell body (rounded cell + terminal + charge
     bars) sitting at the hub of four rotor arms, so it reads as "the aircraft's battery" at a
     glance. Monochrome — HudIcon tints the whole silhouette one color at draw time. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Four arms from the battery hub out to the rotors -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M12,12 L4.4,4.4 M12,12 L19.6,4.4 M12,12 L4.4,19.6 M12,12 L19.6,19.6" />

    <!-- Four rotor rings at the corners -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.4"
        android:fillColor="#00000000"
        android:pathData="M1.9,4.4 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0
                          M17.1,4.4 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0
                          M1.9,19.6 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0
                          M17.1,19.6 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0" />

    <!-- Battery cell body (rounded OUTLINE, not a solid slab, so it reads as a battery) at the hub -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.4"
        android:fillColor="#00000000"
        android:pathData="M8,8.6 h6.4 a1.3,1.3 0 0 1 1.3,1.3 v4.2 a1.3,1.3 0 0 1 -1.3,1.3 h-6.4 a1.3,1.3 0 0 1 -1.3,-1.3 v-4.2 a1.3,1.3 0 0 1 1.3,-1.3 z" />
    <!-- Positive terminal nub -->
    <path
        android:fillColor="#000000"
        android:pathData="M15.7,10.7 h1.0 v2.6 h-1.0 z" />
    <!-- Two charge bars inside the cell so it reads as charged, not empty -->
    <path
        android:fillColor="#000000"
        android:pathData="M9.6,10.4 h1.1 v3.2 h-1.1 z M11.9,10.4 h1.1 v3.2 h-1.1 z" />
</vector>
